# Supabase — Project URL + keys from https://supabase.com/dashboard → Project Settings → API
# The service-role key is SERVER-ONLY. Never expose it to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Resend — API key from https://resend.com/api-keys
# Webhook signing secret from the webhook endpoint you create in Resend (Step 8).
RESEND_API_KEY=re_your_resend_api_key
RESEND_WEBHOOK_SECRET=whsec_your_resend_webhook_secret

# Anthropic — Claude API key from https://console.anthropic.com (for "Write with AI")
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Random 32+ byte secret used to HMAC-sign unsubscribe tokens.
# Generate with: openssl rand -base64 48
UNSUBSCRIBE_TOKEN_SECRET=generate-a-long-random-string-here

# Public base URL of this app. Used to build absolute unsubscribe links in emails.
# Locally: http://localhost:3000 — in Vercel: your production domain.
NEXT_PUBLIC_APP_URL=http://localhost:3000
